+fn hanako_build_option(key: &str) -> Option<String> {
+    let value = match key {
+        keys::OPTION_CUSTOM_RENDEZVOUS_SERVER => option_env!("CONTROL_SERVER_HOST"),
+        keys::OPTION_API_SERVER => option_env!("CONTROL_API_BASE_URL"),
+        keys::OPTION_KEY => option_env!("CONTROL_SERVER_KEY"),
+        _ => None,
+    }?
+    .trim()
+    .trim_end_matches('/')
+    .to_owned();
+    if value.is_empty() {
+        None
+    } else {
+        Some(value)
+    }
+}
+
+fn apply_hanako_build_options(options: &mut HashMap<String, String>) {
+    for key in [
+        keys::OPTION_CUSTOM_RENDEZVOUS_SERVER,
+        keys::OPTION_API_SERVER,
+        keys::OPTION_KEY,
+    ] {
+        if options
+            .get(key)
+            .map(|value| value.is_empty())
+            .unwrap_or(true)
+        {
+            if let Some(value) = hanako_build_option(key) {
+                options.insert(key.to_owned(), value);
+            }
+        }
+    }
+}
+
